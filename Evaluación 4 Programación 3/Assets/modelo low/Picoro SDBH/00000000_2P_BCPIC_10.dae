  <library_effects>
    <effect id="face_01_eff_id" name="face_01_eff">
      <profile_COMMON>
        <newparam sid="face_01_surf">
          <surface type="2D">
            <init_from>pic_0face</init_from>
            <format>PNG</format>
          </surface>
        </newparam>
        <newparam sid="face_01_samp">
          <sampler2D>
            <source>face_01_surf</source>
            <wrap_s>WRAP</wrap_s>
            <wrap_t>WRAP</wrap_t>
            <minfilter>LINEAR_MIPMAP_NEAREST</minfilter>
            <magfilter>LINEAR</magfilter>
            <mipfilter>LINEAR</mipfilter>
          </sampler2D>
        </newparam>
        <technique sid="face_01_tech">
          <phong>
            <diffuse>
              <texture texture="face_01_samp" texcoord="uv" />
            </diffuse>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
